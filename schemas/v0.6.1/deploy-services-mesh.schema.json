{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bootstraplaboratory.github.io/rush-delivery/schemas/v0.6.1/deploy-services-mesh.schema.json",
  "title": "Rush Delivery deploy services mesh",
  "type": "object",
  "required": ["services"],
  "additionalProperties": false,
  "properties": {
    "services": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "deploy_after": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
